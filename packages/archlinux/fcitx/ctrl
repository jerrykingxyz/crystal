#!/usr/bin/env bash

set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

. "$SCRIPT_DIR/../../../lib/env.sh"
init_pkg_env "${BASH_SOURCE[0]}"
. "$ROOT_DIR/lib/archlinux.sh"

ACTION=${1:?}

case "$ACTION" in
    root_setup)
        pacman_install fcitx5 fcitx5-chinese-addons
        ;;
    user_setup)
        create_link "$PKG_DIR/profile" "$HOME/.config/fcitx5/profile"
        ;;
    root_remove)
        pacman_remove fcitx5 fcitx5-chinese-addons
        ;;
    user_remove)
        rm -f "$HOME/.config/fcitx5/profile"
        ;;
    *)
        false
        ;;
esac
