#!/usr/bin/env bash

set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

. "$SCRIPT_DIR/../../../lib/env.sh"
init_pkg_env "${BASH_SOURCE[0]}"
. "$ROOT_DIR/lib/archlinux.sh"

ACTION=${1:?}

case "$ACTION" in
    root_setup)
        pacman_install git
        ;;
    user_setup)
        create_link "$PKG_DIR/.gitconfig" "$HOME/.gitconfig"
        create_link "$PKG_DIR/.gitignore_global" "$HOME/.gitignore_global"
        ;;
    user_remove)
        rm -f "$HOME/.gitconfig" "$HOME/.gitignore_global"
        ;;
    *)
        false
        ;;
esac
