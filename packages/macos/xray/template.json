{
  "log": {
    "loglevel": "none"
  },
  "inbounds": [
    {
      "port": 10800,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "tag": "socks"
    },
    {
      "port": 10801,
      "listen": "127.0.0.1",
      "protocol": "http",
      "tag": "http"
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {},
      "tag": "direct"
    },
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "__server_ip__",
            "port": 8443,
            "users": [
              {
                "id": "__server_user_id__",
                "flow": "xtls-rprx-vision",
                "encryption": "none",
                "level": 0
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.microsoft.com",
          "fingerprint": "chrome",
          "password": "__reality_password__",
          "shortId": ""
        }
      },
      "tag": "proxy"
    },
    {
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "http"
        }
      },
      "tag": "black"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "domain": ["geosite:category-games@cn"],
        "outboundTag": "direct",
        "type": "field"
      },
      {
        "domain": ["geosite:geolocation-!cn", "hanime1.me"],
        "outboundTag": "proxy",
        "type": "field"
      }
    ]
  }
}
