#!/usr/bin/env bash

set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

source "$SCRIPT_DIR/../../../lib/env.sh"
init_pkg_env "${BASH_SOURCE[0]}"
source "$ROOT_DIR/lib/config.sh"

ACTION=${1:?}
CFG_FILE="$PKG_DIR/config"

clear_domains() {
    while true; do
        uci -q delete dhcp.@domain[-1] || break
    done
    uci commit dhcp
}

set_domains() {
    get_config_var "$CFG_FILE" "domains" | while IFS= read -r domain; do
        if [ -n "$domain" ]; then
            uci -q add dhcp domain
            name=${domain%% *}
            ip=${domain#* }
            uci -q set dhcp.@domain[-1].name="$name"
            uci -q set dhcp.@domain[-1].ip="$ip"
        fi
    done
    uci commit dhcp
}

case "$ACTION" in
    root_setup)
        ;;
    root_remove)
        opkg remove smartdns || true
        ;;
    start)
        clear_domains
        set_domains
        /etc/init.d/dnsmasq restart
        ;;
    stop)
        clear_domains
        /etc/init.d/dnsmasq restart
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    config)
        update_config_var "$CFG_FILE" "${2:?}" "${3:?}"
        ;;
    *)
        false
        ;;
esac
