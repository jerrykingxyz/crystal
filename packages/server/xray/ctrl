#!/usr/bin/env bash

set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

. "$SCRIPT_DIR/../../../lib/env.sh"
init_pkg_env "${BASH_SOURCE[0]}"
. "$ROOT_DIR/lib/config.sh"
. "$ROOT_DIR/lib/render.sh"

ACTION=$1
CFG_FILE="$PKG_DIR/config"
TEMPLATE_FILE="$PKG_DIR/template.json"
OUTPUT_CFG_FILE="$TEMP_DIR/config.json"
SHARE_PORT=8001

case "$ACTION" in
    root_setup)
        sh -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install
        ;;
    user_setup)
        keys=$(xray x25519)
        private_key=
        public_key=

        # 按行匹配 key，再从冒号后取值，兼容 Xray 字段名变化。
        while IFS= read -r item; do
            key=$(printf '%s\n' "${item%%:*}" | sed 'y/ABCDEFGHIJKLMNOPQRSTUVWXYZ/abcdefghijklmnopqrstuvwxyz/')
            value=$(printf '%s\n' "${item#*:}" | sed 's/^[[:space:]]*//')

            case "$key" in
                *private*)
                    private_key=$value
                    ;;
                *public*)
                    public_key=$value
                    ;;
            esac
        done <<EOF
$keys
EOF

        if [ -z "$private_key" ] || [ -z "$public_key" ]; then
            false
        fi

        update_config_var "$CFG_FILE" "private_key" "$private_key"
        update_config_var "$CFG_FILE" "public_key" "$public_key"

        share_token=$(LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 32)
        update_config_var "$CFG_FILE" "share_token" "$share_token"
        ;;
    start)
        mkdir -p "$TEMP_DIR"
        render_config "$TEMPLATE_FILE" "$CFG_FILE" > "$OUTPUT_CFG_FILE"
        xray -c "$OUTPUT_CFG_FILE" &
        ;;
    stop)
        pids=$(pgrep -f "$OUTPUT_CFG_FILE" 2>/dev/null || true)
        if [ ! -z "$pids" ]; then
            kill $pids || true
        fi
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    share)
        rm -rf "$TEMP_DIR/share"
        mkdir -p "$TEMP_DIR/share"
        token=$(get_config_var "$CFG_FILE" "share_token")
        server_ip=$(ip route get 1.1.1.1 | awk '{ for (i=1; i<NF; i++) if ($i=="src") print $(i+1) }')

        if [ -z "$server_ip" ]; then
            false
        fi

        user_id=$(get_config_var "$CFG_FILE" "user_id")
        domain=$(get_config_var "$CFG_FILE" "domain")
        public_key=$(get_config_var "$CFG_FILE" "public_key")
        vless_url="vless://$user_id@$server_ip:443?encryption=none&security=reality&type=tcp&flow=xtls-rprx-vision&sni=$domain&fp=chrome&pbk=$public_key&sid=#server-xray"

        printf '%s\n' "$vless_url" | base64 | tr -d '\n' > "$TEMP_DIR/share/$token.txt"
        printf '%s\n' "http://$server_ip:$SHARE_PORT/$token.txt"
        python3 -m http.server "$SHARE_PORT" --bind 0.0.0.0 --directory "$TEMP_DIR/share"
        ;;
    config)
        update_config_var "$CFG_FILE" "${2:?}" "${3:?}"
        ;;
    *)
        false
        ;;
esac
