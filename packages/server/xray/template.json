{
  "log": {
    "loglevel": "none"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__server_user_id__",
            "flow": "xtls-rprx-vision",
            "level": 0,
            "email": "__server_email__"
          }
        ],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": 81,
            "xver": 0
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/letsencrypt/live/__server_hostname__/fullchain.pem",
              "keyFile": "/etc/letsencrypt/live/__server_hostname__/privkey.pem"
            }
          ]
        }
      }
    },
    {
      "port": 3000,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__server_user_id__",
            "flow": "xtls-rprx-vision",
            "level": 0,
            "email": "__server_email__"
          }
        ],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": 81,
            "xver": 0
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/letsencrypt/live/__server_hostname__/fullchain.pem",
              "keyFile": "/etc/letsencrypt/live/__server_hostname__/privkey.pem"
            }
          ]
        }
      }
    },
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__server_user_id__",
            "flow": "xtls-rprx-vision",
            "level": 0,
            "email": "__server_email__"
          }
        ],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": 81,
            "xver": 0
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/letsencrypt/live/__server_hostname__/fullchain.pem",
              "keyFile": "/etc/letsencrypt/live/__server_hostname__/privkey.pem"
            }
          ]
        }
      }
    },
    {
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__server_user_id__",
            "flow": "xtls-rprx-vision",
            "level": 0,
            "email": "__server_email__"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "target": "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com"],
          "privateKey": "__reality_private_key__",
          "shortIds": __reality_short_ids__
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom"
    },
    {
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      },
      "tag": "refuse"
    }
  ],
  "routing": {
    "domainStrategy": "IPOnDemand",
    "rules": [
      {
        "type": "field",
        "outboundTag": "refuse",
        "domain": ["geosite:cn", "geosite:category-ads-all"]
      },
      {
        "type": "field",
        "outboundTag": "refuse",
        "ip": ["geoip:cn", "geoip:private"]
      }
    ]
  }
}
