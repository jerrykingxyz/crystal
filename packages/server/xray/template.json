{
  "log": {
    "loglevel": "none"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__user_id__",
            "flow": "xtls-rprx-vision",
            "level": 0,
            "email": "__email__"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "target": "__domain__:443",
          "serverNames": ["__domain__"],
          "privateKey": "__private_key__",
          "shortIds": [""]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      },
      "tag": "refuse"
    }
  ],
  "routing": {
    "domainStrategy": "IPOnDemand",
    "rules": [
      {
        "type": "field",
        "outboundTag": "direct",
        "domain": ["geosite:google", "geosite:openai"]
      },
      {
        "type": "field",
        "outboundTag": "refuse",
        "domain": ["geosite:cn", "geosite:category-ads"]
      },
      {
        "type": "field",
        "outboundTag": "refuse",
        "ip": ["geoip:private"]
      }
    ]
  }
}
